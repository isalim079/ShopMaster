# =========================
# Application
# =========================
NODE_ENV=development
PORT=5000
API_VERSION=v1
APP_NAME=ShopMaster
SERVER_URL=http://localhost:5000

# =========================
# Database (PostgreSQL)
# =========================
DATABASE_URL=

# =========================
# Redis
# =========================
REDIS_URL=

# =========================
# JWT
# =========================
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_PASSWORD_RESET_SECRET=
JWT_PASSWORD_RESET_EXPIRES_IN=15m

# =========================
# Email (SMTP)
# =========================
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_FROM_NAME=ShopMaster

# =========================
# Security
# =========================
BCRYPT_SALT_ROUNDS=12
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10
CORS_ALLOWED_ORIGINS=http://localhost:8081

# =========================
# Rate Limiting
# =========================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# =========================
# Logging
# =========================
LOG_LEVEL=info
LOG_FILE_PATH=logs/app.log

# =========================
# Organization defaults
# =========================
ORGANIZATION_DEFAULT_CURRENCY=BDT
ORGANIZATION_DEFAULT_TIMEZONE=Asia/Dhaka

# =========================
# Settings defaults
# =========================
SETTING_DEFAULT_INVOICE_PREFIX=INV
SETTING_DEFAULT_INVOICE_NEXT_NUMBER=1
SETTING_DEFAULT_PURCHASE_PREFIX=PO
SETTING_DEFAULT_PURCHASE_NEXT_NUMBER=1
SETTING_DEFAULT_PURCHASE_RETURN_PREFIX=PR
SETTING_DEFAULT_PURCHASE_RETURN_NEXT_NUMBER=1
SETTING_DEFAULT_SALE_RETURN_PREFIX=SR
SETTING_DEFAULT_SALE_RETURN_NEXT_NUMBER=1
SETTING_DEFAULT_LOW_STOCK_THRESHOLD=10
SETTING_DEFAULT_ALLOW_NEGATIVE_STOCK=false
SETTING_DEFAULT_DATE_FORMAT=DD/MM/YYYY
SETTING_DEFAULT_DECIMAL_PLACES=2

# =========================
# Uploads
# =========================
UPLOAD_DIR=uploads
UPLOAD_MAX_BYTES=10485760
UPLOAD_ALLOWED_MIME=image/png,image/jpeg,image/jpg,image/gif,image/webp,application/pdf
UPLOAD_STATIC_PATH=/uploads/files
